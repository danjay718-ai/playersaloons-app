# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=PlayerSaloons
APP_ENV=production
APP_KEY=                        # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_LEVEL=error

# ─── Database (MySQL — from Render DB) ────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=                        # from Render MySQL service
DB_PORT=3306
DB_DATABASE=playersaloons
DB_USERNAME=                    # from Render MySQL service
DB_PASSWORD=                    # from Render MySQL service

# ─── Redis (from Render Redis) ────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=                     # from Render Redis service
REDIS_PORT=6379
REDIS_PASSWORD=                 # from Render Redis service
REDIS_PREFIX=
REDIS_DEFAULT_PREFIX=ps:default:
REDIS_CACHE_PREFIX=ps:cache:
REDIS_SESSION_PREFIX=ps:session:
REDIS_QUEUE_PREFIX=ps:queue:
REDIS_REVERB_PREFIX=ps:reverb:

# ─── Session / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_CONNECTION=session
CACHE_STORE=redis
REDIS_CACHE_CONNECTION=cache
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=queue

# ─── Broadcasting (Reverb) ────────────────────────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=                  # generate a random ID
REVERB_APP_KEY=                 # generate a random key
REVERB_APP_SECRET=              # generate a random secret
REVERB_HOST=your-reverb.onrender.com
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── File Storage (local public disk — ephemeral on Render) ──────────────────
FILESYSTEM_DISK=public
MEDIA_DISK=public

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=info@playersaloons.com
MAIL_FROM_NAME="${APP_NAME}"
