# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=PlayerSaloons
APP_ENV=production
APP_KEY=                        # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://yourdomain.com  # your actual domain pointed to Linode IP

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
BCRYPT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_LEVEL=error

# ─── Database (MySQL — runs in mysql container) ───────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql                   # service name in docker-compose.prod.yml
DB_PORT=3306
DB_DATABASE=playersaloons
DB_USERNAME=playersaloons
DB_PASSWORD=                    # strong password
DB_ROOT_PASSWORD=               # strong root password (for mysql container)

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis                # service name in docker-compose.prod.yml
REDIS_PORT=6379
REDIS_PASSWORD=                 # strong password (matches redis container)
REDIS_PREFIX=
REDIS_DEFAULT_PREFIX=ps:default:
REDIS_CACHE_PREFIX=ps:cache:
REDIS_SESSION_PREFIX=ps:session:
REDIS_QUEUE_PREFIX=ps:queue:
REDIS_REVERB_PREFIX=ps:reverb:

# ─── Session / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_CONNECTION=session
CACHE_STORE=redis
REDIS_CACHE_CONNECTION=cache
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=queue

# ─── Broadcasting (Reverb) ────────────────────────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=                  # random string e.g. openssl rand -hex 8
REVERB_APP_KEY=                 # random string e.g. openssl rand -hex 16
REVERB_APP_SECRET=              # random string e.g. openssl rand -hex 32
REVERB_HOST=yourdomain.com      # your domain (Coolify handles SSL termination)
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── File Storage ─────────────────────────────────────────────────────────────
FILESYSTEM_DISK=public
MEDIA_DISK=public

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=info@playersaloons.com
MAIL_FROM_NAME="${APP_NAME}"
